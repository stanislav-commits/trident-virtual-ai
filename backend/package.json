{
  "name": "trident-virtual-ai-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Fresh NestJS backend for Trident Virtual AI",
  "scripts": {
    "build": "nest build",
    "db:down": "docker compose down",
    "db:migrate": "typeorm-ts-node-commonjs -d src/core/database/typeorm.datasource.ts migration:run",
    "db:seed": "ts-node -r tsconfig-paths/register src/core/database/seeds/dev.seed.ts",
    "db:up": "docker compose up -d postgres",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@influxdata/influxdb-client": "^1.35.0",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/typeorm": "^11.0.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.4.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.24"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.6",
    "@types/node": "^22.15.21",
    "@types/passport-jwt": "^4.0.1",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.8.3"
  }
}
