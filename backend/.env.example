# Application
APP_NAME=trident-virtual-ai-backend
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database connection
DB_HOST=localhost
DB_PORT=5433
DB_NAME=trident_virtual_ai
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Chat feature gates
CHAT_DOCUMENTS_RESPONDER_ENABLED=false

# Influx integration
INFLUX_URL=
INFLUX_ORG=
INFLUX_TOKEN=
INFLUX_SCHEMA_LOOKBACK=-3650d

# Grafana metric descriptions
GRAFANA_LLM_BASE_URL=
GRAFANA_SA_TOKEN=
GRAFANA_LLM_MODEL=gpt-4o

# Optional general LLM integration
RAG_PROVIDER=local
RAG_INDEX_NAME=
WEB_SEARCH_BASE_URL=
WEB_SEARCH_API_KEY=
WEB_SEARCH_MODEL=gpt-5.2
LLM_PROVIDER=openai
LLM_BASE_URL=
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=
