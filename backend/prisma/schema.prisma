// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  user
}

enum ChatRole {
  user
  assistant
  system
}

model User {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  name         String?  @db.VarChar(255)
  passwordHash String   @map("password_hash")
  role         Role     @default(user)
  shipId       String?  @map("ship_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  ship         Ship?         @relation(fields: [shipId], references: [id], onDelete: SetNull)
  chatSessions ChatSession[]

  @@map("users")
}

model MetricDefinition {
  key         String   @id @db.VarChar(255)
  label       String   @db.VarChar(100)
  description String?  @db.Text
  unit        String?  @db.VarChar(20)
  bucket      String?  @db.VarChar(128)
  measurement String?  @db.VarChar(255)
  field       String?  @db.VarChar(255)
  firstSeenAt DateTime? @map("first_seen_at")
  lastSeenAt  DateTime? @map("last_seen_at")
  status      String   @default("active") @db.VarChar(20)
  dataType    String   @default("numeric") @map("data_type") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")

  configs ShipMetricsConfig[]
}

model Ship {
  id               String   @id @default(uuid()) @db.Uuid
  name             String   @db.VarChar(255)
  organizationName String?  @unique @map("organization_name") @db.VarChar(100)
  imoNumber        String?  @map("imo_number") @db.VarChar(20)
  flag             String?  @db.VarChar(100)
  deadweight       Int?
  grossTonnage     Int?     @map("gross_tonnage")
  buildYard        String?  @map("build_yard") @db.VarChar(255)
  shipClass        String?  @map("class_name") @db.VarChar(255)
  metricsSyncStatus String  @default("idle") @map("metrics_sync_status") @db.VarChar(20)
  metricsSyncError  String? @map("metrics_sync_error") @db.Text
  metricsSyncedAt   DateTime? @map("metrics_synced_at")
  lastTelemetry    Json     @default("{}") @map("last_telemetry")
  ragflowDatasetId String?  @map("ragflow_dataset_id") @db.VarChar(255)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  assignedUsers User[]
  metricsConfig ShipMetricsConfig[]
  manuals       ShipManual[]
  chatSessions  ChatSession[]
}

model ShipManual {
  id                String   @id @default(cuid())
  shipId            String   @map("ship_id") @db.Uuid
  ragflowDocumentId String   @map("ragflow_document_id") @db.VarChar(255)
  filename          String   @db.VarChar(500)
  category          String   @default("MANUALS") @db.VarChar(32)
  uploadedAt        DateTime @default(now()) @map("uploaded_at")

  ship              Ship                   @relation(fields: [shipId], references: [id], onDelete: Cascade)
  contextReferences ChatContextReference[]

  @@unique([shipId, ragflowDocumentId])
  @@index([shipId, category])
  @@map("ship_manuals")
}

model ShipMetricsConfig {
  shipId         String    @map("ship_id") @db.Uuid
  metricKey      String    @map("metric_key") @db.VarChar(255)
  isActive       Boolean   @default(true) @map("is_active")
  latestValue    Json?     @map("latest_value") @db.JsonB
  valueUpdatedAt DateTime? @map("value_updated_at")

  ship   Ship             @relation(fields: [shipId], references: [id], onDelete: Cascade)
  metric MetricDefinition @relation(fields: [metricKey], references: [key])

  @@id([shipId, metricKey])
}

// Partitioned by RANGE(created_at) in DB; do not change createdAt type or Prisma will generate breaking ALTERs.
model TelemetryHistory {
  id        BigInt   @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  shipId    String   @map("ship_id") @db.Uuid
  payload   Json

  @@id([id, createdAt])
  @@map("telemetry_history")
}

model ChatSession {
  id        String    @id @default(cuid())
  title     String?   @db.VarChar(500)
  userId    String    @map("user_id")
  shipId    String?   @map("ship_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  messages ChatMessage[]

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  ship Ship? @relation(fields: [shipId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
  @@index([shipId])
  @@index([createdAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id             String    @id @default(cuid())
  sessionId      String    @map("session_id")
  role           ChatRole
  content        String    @db.Text
  ragflowContext Json?     @map("ragflow_context") // keep technical metadata
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  contextReferences ChatContextReference[]

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model ChatContextReference {
  id           String  @id @default(cuid())
  messageId    String  @map("message_id")
  shipManualId String? @map("ship_manual_id")
  chunkId      String? @map("chunk_id")
  score        Float?
  pageNumber   Int?    @map("page_number")
  startOffset  Int?    @map("start_offset")
  endOffset    Int?    @map("end_offset")
  snippet      String? @db.Text
  sourceTitle  String? @map("source_title")
  sourceUrl    String? @map("source_url")

  message    ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  shipManual ShipManual? @relation(fields: [shipManualId], references: [id], onDelete: SetNull)

  @@index([messageId])
  @@index([shipManualId])
  @@map("chat_context_references")
}
