// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  user
}

model User {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  passwordHash String   @map("password_hash")
  role         Role     @default(user)
  shipId       String?  @map("ship_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  ship Ship? @relation(fields: [shipId], references: [id], onDelete: SetNull)

  @@map("users")
}

model MetricDefinition {
  key       String   @id @db.VarChar(50)
  label     String   @db.VarChar(100)
  description String?  @db.Text
  unit      String?  @db.VarChar(20)
  dataType  String   @default("numeric") @map("data_type") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  configs ShipMetricsConfig[]
}

model Ship {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String   @db.VarChar(255)
  serialNumber       String?  @unique @map("serial_number") @db.VarChar(100)
  lastTelemetry      Json     @default("{}") @map("last_telemetry")
  ragflowDatasetId   String?  @map("ragflow_dataset_id") @db.VarChar(255)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  assignedUsers User[]
  metricsConfig ShipMetricsConfig[]
  manuals       ShipManual[]
}

model ShipManual {
  id                 String   @id @default(cuid())
  shipId             String   @map("ship_id") @db.Uuid
  ragflowDocumentId  String   @map("ragflow_document_id") @db.VarChar(255)
  filename           String   @db.VarChar(500)
  uploadedAt         DateTime @default(now()) @map("uploaded_at")

  ship Ship @relation(fields: [shipId], references: [id], onDelete: Cascade)

  @@unique([shipId, ragflowDocumentId])
  @@map("ship_manuals")
}

model ShipMetricsConfig {
  shipId    String @map("ship_id") @db.Uuid
  metricKey String @map("metric_key") @db.VarChar(50)
  isActive  Boolean @default(true) @map("is_active")

  ship   Ship             @relation(fields: [shipId], references: [id], onDelete: Cascade)
  metric MetricDefinition @relation(fields: [metricKey], references: [key])

  @@id([shipId, metricKey])
}

// Partitioned by RANGE(created_at) in DB; do not change createdAt type or Prisma will generate breaking ALTERs.
model TelemetryHistory {
  id        BigInt   @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  shipId    String   @map("ship_id") @db.Uuid
  payload   Json

  @@id([id, createdAt])
  @@map("telemetry_history")
}